{
  "name": "thinqshop-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:web": "npm run dev -w web",
    "dev:mobile": "npm run start -w mobile",
    "build:web:docker": "docker build -f web/Dockerfile -t thinqshop-web .",
    "build:backend:docker": "docker build -f backend/Dockerfile -t thinqshop-backend .",
    "clean": "rm -rf backend/dist web/.next"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}