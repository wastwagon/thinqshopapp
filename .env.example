# Backend Environment Variables
DATABASE_URL="postgresql://thinq_user:thinq_password@localhost:5432/thinqshop_db"
# Required. No default in production (backend will not start without it).
JWT_SECRET="your_secret_key"
# CORS: comma-separated frontend origins (e.g. http://localhost:3000,https://yourdomain.com). Omit to allow all.
FRONTEND_URL="http://localhost:3000"

# Optional: error tracking (backend). Set SENTRY_DSN to enable.
# SENTRY_DSN=

# Optional: email queue processor (npm run email:process). SMTP for sending queued emails.
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@thinqshopping.app

# Paystack (use live keys for production: sk_live_... and pk_live_...)
# Backend: secret key for server-side verification (never expose in frontend)
PAYSTACK_SECRET_KEY="sk_live_your_secret_or_sk_test_for_testing"
# Frontend: public key for Paystack popup (wallet top-up, transfers, ecommerce)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_your_public_or_pk_test_for_testing"

# Arkesel SMS (user notifications: orders, shipments, transfers). Get API key at https://sms.arkesel.com
# ARKESEL_API_KEY=your_arkesel_api_key
# ARKESEL_SENDER_ID=ThinQShop

# Frontend / Next.js (web)
# Backend API base URL: used by Next.js API proxy and SSR. Must be the NestJS backend, not the Next.js app.
NEXT_PUBLIC_API_URL="http://localhost:7000"
# Currency converter: show USD/CNY alongside GHS on product cards, cart, checkout. Default: false.
# NEXT_PUBLIC_SHOW_CURRENCY_CONVERTER=false
# Optional: server-side only override for API proxy (e.g. in Docker use http://host.docker.internal:7000)
# BACKEND_URL="http://localhost:7000"
# Optional public social URLs (if set, navbar/footer will render links)
# NEXT_PUBLIC_INSTAGRAM_URL=
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_FACEBOOK_URL=

# Operational safety: keep runtime DB migrate/seed endpoints disabled in production.
# Set true only for temporary controlled maintenance windows.
# ENABLE_RUNTIME_DB_ADMIN=false
